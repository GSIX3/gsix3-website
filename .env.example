# ─────────────────────────────────────────────────────────────────────────────
# Environment template for the GSIX3 website (Next.js).
#
# Copy this file to ".env.local" and adjust the values:
#     cp .env.example .env.local        # macOS / Linux
#     copy .env.example .env.local      # Windows
#
# Notes:
#  • NEXT_PUBLIC_* variables are exposed to the browser and embedded in the
#    build — they are PUBLIC. Never put secrets (API keys, etc.) here; secrets
#    live on the backend (see the FastAPI email service).
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the FastAPI email service that powers the contact form.
# The contact form POSTs to `${NEXT_PUBLIC_EMAIL_API}/contact`.
# Local dev default below; in production use the deployed backend URL.
NEXT_PUBLIC_EMAIL_API=http://localhost:8000
